# Coordinator Configuration
PORT=3001
DB_PATH=coordinator.db

# CORS — set to your frontend's production URL
CORS_ORIGIN=https://motonero.org

# Admin API key — minimum 32 characters (generate with: openssl rand -hex 32)
ADMIN_API_KEY=

# Field-level encryption key — 64 hex chars (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=

# TLS enforcement
REQUIRE_TLS=false

# OPNet SwapVault contract address
SWAP_CONTRACT_ADDRESS=opt1sqpfk6a2m6ngae8yyztvrsmd0efup67pleuf243nm

# Monero settings — MAINNET
MONERO_MOCK=false
MONERO_NETWORK=mainnet
XMR_FEE_ADDRESS=4Atk74FPPMsYLh7nh11D7sXGomjzijP58GQccTppi7egWKNjthZeimHhrioWFWL3AyUSMxhSssEHnQ8GXCEUb8YWH98YqMH
XMR_WALLET_RPC_URL=http://localhost:18082/json_rpc
XMR_WALLET_RPC_USER=
XMR_WALLET_RPC_PASS=
XMR_POLL_INTERVAL_MS=30000
XMR_DAEMON_URL=http://node.monerodevs.org:18089

# Wallet auto-open on startup (set name + password so coordinator opens it)
XMR_WALLET_NAME=
XMR_WALLET_PASS=
